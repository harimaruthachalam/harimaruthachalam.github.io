---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import MetricTiles from "../components/MetricTiles.astro";
import SelectedWork from "../components/SelectedWork.astro";
import Experience from "../components/Experience.astro";
import Publications from "../components/Publications.astro";
import EducationSkills from "../components/EducationSkills.astro";
import Recognition from "../components/Recognition.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/profile";

// JSON-LD: makes Google show a rich card for the name search.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: "Staff Data Scientist",
  description: profile.about,
  email: profile.emails.primary,
  url: "https://harimaruthachalam.github.io",
  sameAs: profile.socials.map((s) => s.url),
  alumniOf: [
    {
      "@type": "CollegeOrUniversity",
      name: "Indian Institute of Technology, Madras",
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Anna University, Chennai",
    },
  ],
};
---

<Base>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personSchema)}
    slot="head"
  />

  <Hero />
  <MetricTiles />
  <SelectedWork />
  <Experience />
  <Publications />
  <EducationSkills />
  <Recognition />
  <Contact />
  <Footer />
</Base>

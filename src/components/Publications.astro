---
import { publications } from "../data/publications";
import { profile } from "../data/profile";
import { collaboratorByName } from "../data/collaborators";

const scholarUrl = profile.socials.find((s) => s.icon === "scholar")?.url;
---

<section id="publications" class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
  <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-fg-dim)]">
    Publications
  </p>
  <h2
    class="mt-3 max-w-2xl font-serif text-4xl leading-tight tracking-tight sm:text-5xl"
    style="font-family: var(--font-serif);"
  >
    Peer-reviewed.
  </h2>

  <ol class="mt-16 space-y-12">
    {
      publications.map((p) => (
        <li class="grid grid-cols-12 gap-6 border-t border-[var(--color-border)] pt-8">
          <div class="col-span-12 sm:col-span-3">
            <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-dim)]">
              {p.venue}
            </p>
            {p.location && (
              <p class="mt-1 text-xs text-[var(--color-fg-dim)]">{p.location}</p>
            )}
          </div>

          <div class="col-span-12 sm:col-span-9">
            <h3
              class="font-serif text-xl leading-snug text-[var(--color-fg)] sm:text-2xl"
              style="font-family: var(--font-serif);"
            >
              {p.title}
            </h3>
            <p class="mt-3 text-sm text-[var(--color-fg-muted)]">
              {p.authors.map((a, i) => {
                const collab = collaboratorByName[a];
                const isMe = a === "Srihari Maruthachalam";
                return (
                  <span>
                    {isMe ? (
                      <span class="font-medium text-[var(--color-fg)]">{a}</span>
                    ) : collab ? (
                      <a
                        href={collab.url}
                        target="_blank"
                        rel="noopener"
                        class="collab-link"
                      >
                        {a}
                      </a>
                    ) : (
                      a
                    )}
                    {i < p.authors.length - 1 && ", "}
                  </span>
                );
              })}
            </p>
            <p class="mt-1 text-xs text-[var(--color-fg-dim)]">{p.citation}</p>
            {p.takeaway && (
              <p class="mt-4 max-w-2xl border-l-2 border-[var(--color-accent)] pl-4 text-sm italic text-[var(--color-fg-muted)]">
                {p.takeaway}
              </p>
            )}
            <p class="mt-4">
              <a
                href={p.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1 text-sm text-[var(--color-accent)] underline decoration-[var(--color-accent)]/30 underline-offset-4 transition hover:decoration-[var(--color-accent)]"
              >
                Read paper <span aria-hidden="true">↗</span>
              </a>
            </p>
          </div>
        </li>
      ))
    }
  </ol>

  {
    scholarUrl && (
      <p class="mt-12 text-sm text-[var(--color-fg-dim)]">
        More on{" "}
        <a
          href={scholarUrl}
          target="_blank"
          rel="noopener"
          class="text-[var(--color-fg-muted)] underline underline-offset-4 transition hover:text-[var(--color-fg)]"
        >
          Google Scholar
        </a>
        .
      </p>
    )
  }
</section>

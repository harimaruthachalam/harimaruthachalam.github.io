---
import { profile } from "../data/profile";
import SocialIcon from "./SocialIcon.astro";
---

<section
  id="contact"
  class="border-t border-[var(--color-border)] bg-[var(--color-bg-soft)]"
>
  <div class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
    <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-fg-dim)]">
      Get in touch
    </p>

    <h2
      class="mt-3 max-w-3xl font-serif text-5xl leading-tight tracking-tight sm:text-6xl"
      style="font-family: var(--font-serif);"
    >
      Have a problem worth <span class="text-[var(--color-accent)] italic">solving?</span>
    </h2>

    <p class="mt-8 max-w-2xl text-lg text-[var(--color-fg-muted)]">
      I read my mailbox regularly. The fastest way to reach me is email.
    </p>

    <div class="mt-12 grid gap-12 sm:grid-cols-2">
      <div>
        <p class="text-xs uppercase tracking-wider text-[var(--color-fg-dim)]">
          Email
        </p>
        <a
          href={`mailto:${profile.emails.primary}`}
          class="mt-3 block font-mono text-base text-[var(--color-fg)] underline decoration-[var(--color-accent)]/40 underline-offset-4 transition hover:decoration-[var(--color-accent)]"
        >
          {profile.emails.primary}
        </a>
        <a
          href={`mailto:${profile.emails.alumni}`}
          class="mt-1 block font-mono text-sm text-[var(--color-fg-muted)] underline decoration-[var(--color-border-strong)] underline-offset-4 transition hover:text-[var(--color-fg)]"
        >
          {profile.emails.alumni}
        </a>
      </div>

      <div>
        <p class="text-xs uppercase tracking-wider text-[var(--color-fg-dim)]">
          Elsewhere
        </p>
        <ul class="mt-3 flex flex-wrap items-center gap-4">
          {
            profile.socials.map((s) => (
              <li>
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2 text-sm text-[var(--color-fg-muted)] transition hover:border-[var(--color-border-strong)] hover:text-[var(--color-fg)]"
                >
                  <SocialIcon name={s.icon} class="h-4 w-4" />
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

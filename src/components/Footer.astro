---
import { profile } from "../data/profile";

const year = new Date().getFullYear();
const updated = new Date().toLocaleDateString("en-GB", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<footer class="border-t border-[var(--color-border)]">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-3 px-6 py-10 text-xs text-[var(--color-fg-dim)] sm:flex-row sm:items-center"
  >
    <p>© {year} {profile.name}. All rights reserved.</p>
    <p>Updated {updated}</p>
  </div>
</footer>

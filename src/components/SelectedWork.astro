---
import { projects } from "../data/projects";
---

<section id="work" class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
  <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-fg-dim)]">
    Selected work
  </p>
  <h2
    class="mt-3 max-w-2xl font-serif text-4xl leading-tight tracking-tight sm:text-5xl"
    style="font-family: var(--font-serif);"
  >
    Five projects that hold up <span class="text-[var(--color-fg-muted)] italic">in production.</span>
  </h2>

  <ol class="mt-16 space-y-px">
    {
      projects.map((p, i) => (
        <li class="group relative grid grid-cols-12 gap-6 border-t border-[var(--color-border)] py-10 transition hover:bg-[var(--color-bg-soft)]">
          <div class="col-span-12 sm:col-span-3">
            <p class="text-xs font-mono uppercase tracking-wider text-[var(--color-fg-dim)]">
              {String(i + 1).padStart(2, "0")} · {p.year}
            </p>
            <p class="mt-1 text-sm font-medium text-[var(--color-fg-muted)]">
              {p.context}
            </p>
          </div>

          <div class="col-span-12 sm:col-span-9">
            <h3
              class="font-serif text-2xl leading-snug text-[var(--color-fg)] sm:text-3xl"
              style="font-family: var(--font-serif);"
            >
              {p.name}
            </h3>
            <p class="mt-3 text-[var(--color-fg-muted)]">
              <span class="text-[var(--color-fg)]">Problem.</span> {p.problem}
            </p>
            <p class="mt-2 text-[var(--color-fg-muted)]">
              <span class="text-[var(--color-fg)]">Approach.</span> {p.solution}
            </p>
            <p class="mt-4 inline-block rounded border border-[var(--color-accent)]/30 bg-[var(--color-accent-bg)] px-3 py-1.5 text-sm text-[var(--color-accent-soft)]">
              {p.outcome}
            </p>

            <ul class="mt-5 flex flex-wrap gap-2">
              {p.stack.map((t) => (
                <li class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg-elev)] px-3 py-0.5 text-xs text-[var(--color-fg-muted)]">
                  {t}
                </li>
              ))}
            </ul>

            {p.link && (
              <p class="mt-5">
                <a
                  href={p.link.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1 text-sm text-[var(--color-accent)] underline decoration-[var(--color-accent)]/30 underline-offset-4 transition hover:decoration-[var(--color-accent)]"
                >
                  {p.link.label}
                  <span aria-hidden="true">↗</span>
                </a>
              </p>
            )}
          </div>
        </li>
      ))
    }
  </ol>
</section>

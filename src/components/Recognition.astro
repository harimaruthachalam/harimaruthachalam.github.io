---
import { awards } from "../data/awards";
import { talks } from "../data/talks";
---

<section id="recognition" class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
  <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-fg-dim)]">
    Recognition & Conferences
  </p>
  <h2
    class="mt-3 max-w-2xl font-serif text-4xl leading-tight tracking-tight sm:text-5xl"
    style="font-family: var(--font-serif);"
  >
    Beyond the day job.
  </h2>

  <div class="mt-16 grid gap-16 lg:grid-cols-2">
    <!-- Awards -->
    <div>
      <p class="text-xs uppercase tracking-wider text-[var(--color-fg-dim)]">
        Awards
      </p>
      <ul class="mt-6 space-y-5">
        {
          awards.map((a) => (
            <li class="border-l-2 border-[var(--color-accent)]/60 pl-4">
              <p class="text-sm font-medium text-[var(--color-fg)]">
                {a.title}
              </p>
              <p class="text-xs text-[var(--color-fg-dim)]">
                {a.by} · {a.date}
              </p>
              {a.note && (
                <p class="mt-1 text-xs text-[var(--color-fg-muted)]">{a.note}</p>
              )}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Talks / Conferences attended -->
    <div>
      <p class="text-xs uppercase tracking-wider text-[var(--color-fg-dim)]">
        Conferences & workshops attended
      </p>
      <ul class="mt-6 space-y-3">
        {
          talks.map((t) => (
            <li class="flex items-baseline justify-between gap-4 border-b border-[var(--color-border)] pb-3 text-sm">
              <span class="text-[var(--color-fg-muted)]">{t.event}</span>
              <span class="shrink-0 font-mono text-xs text-[var(--color-fg-dim)]">
                {t.location} · {t.year}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
